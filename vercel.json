{
    "headers": [
        {
            "source": "/index.html",
            "headers": [
                { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
                { "key": "Pragma", "value": "no-cache" },
                { "key": "Expires", "value": "0" }
            ]
        },
        {
            "source": "/",
            "headers": [
                { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
                { "key": "Pragma", "value": "no-cache" },
                { "key": "Expires", "value": "0" }
            ]
        },
        {
            "source": "/assets/(.*)",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/api/wms/:path*",
            "destination": "http://170.82.192.22:9999/:path*"
        },
        {
            "source": "/api/escalasoft/:path*",
            "destination": "http://170.82.192.22:9999/escalasoft/:path*"
        },
        {
            "source": "/api/escalasoft-oms/:path*",
            "destination": "https://api.escalasoft.com.br/:path*"
        },
        {
            "source": "/api/jamef-prod/:path*",
            "destination": "https://api.jamef.com.br/:path*"
        },
        {
            "source": "/api/focus-nfe/:path*",
            "destination": "https://api.focusnfe.com.br/:path*"
        },
        {
            "source": "/nf/:nf",
            "destination": "/api/nf/:nf"
        },
        {
            "source": "/((?!api|assets|nf).*)",
            "destination": "/index.html"
        }
    ]
}