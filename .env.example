# Copie para .env e preencha com valores reais. NUNCA commite o .env.

# SUPABASE
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# FOCUS NFE (por filial)
VITE_FOCUS_NFE_TOKEN_CE=
VITE_FOCUS_NFE_TOKEN_SP=
VITE_FOCUS_NFE_TOKEN_SC=

# WHATSAPP
VITE_WHATSAPP_API_TOKEN=
VITE_SALES_WHATSAPP=

# APP
VITE_APP_NAME="StockVision MCI Gestão"
VITE_ENVIRONMENT=production

# CORREIOS - API CWS
# Credenciais ficam SERVER-SIDE (segredos da Edge Function correios-cotacao),
# nunca no cliente. Configure via: npx supabase secrets set CORREIOS_...=...
#   CORREIOS_USUARIO, CORREIOS_CODIGO_ACESSO, CORREIOS_CARTAO_POSTAGEM,
#   CORREIOS_CONTRATO, CORREIOS_DR, CORREIOS_SERVICOS
# No cliente fica só o flag não-secreto:
VITE_CORREIOS_ENABLED=true
